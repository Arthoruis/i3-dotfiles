vim .config/i3blocks/config 
cat > ~/.config/i3blocks/statusbar/mediaplayer << 'EOF'
#!/usr/bin/env bash

# Simple media player block using playerctl.
# Works with cmus (via MPRIS) and other MPRIS players (spotify, vlc, etc.)

PLAYER="${BLOCK_INSTANCE:-cmus}"

artist=$(playerctl --player="$PLAYER" metadata artist 2>/dev/null)
title=$(playerctl --player="$PLAYER" metadata title 2>/dev/null)
status=$(playerctl --player="$PLAYER" status 2>/dev/null)

# No player / no metadata -> show nothing
if [ -z "$status" ] || [ "$status" = "Stopped" ]; then
    exit 0
fi

# Click actions
case "$BLOCK_BUTTON" in
    1) playerctl --player="$PLAYER" previous >/dev/null 2>&1 ;;
    2) playerctl --player="$PLAYER" play-pause >/dev/null 2>&1 ;;
    3) playerctl --player="$PLAYER" next >/dev/null 2>&1 ;;
    4) playerctl --player="$PLAYER" volume 0.01+ >/dev/null 2>&1 ;;
    5) playerctl --player="$PLAYER" volume 0.01- >/dev/null 2>&1 ;;
esac

text=""
[ -n "$artist" ] && text="$artist"
[ -n "$title" ] && text="${text:+$text - }$title"

echo "$text"
EOF

chmod +x ~/.config/i3blocks/statusbar/mediaplayer
cat > ~/.config/i3blocks/statusbar/mediaplayer << 'EOF'
#!/usr/bin/env bash

# Media player block using playerctl with auto-detection.
# Supports: cmus, spotify, vlc, mpv, rhythmbox, and any MPRIS player.

# If BLOCK_INSTANCE is set, use that as the exact player name.
if [ -n "$BLOCK_INSTANCE" ]; then
    PLAYER="$BLOCK_INSTANCE"
else
    # Auto-detect: list active players
    players=$(playerctl -l 2>/dev/null | tr '\n' ' ')
    # Priority list – can adjust order if you like
    priority=(cmus spotify vlc mpv rhythmbox chromium firefox)

    PLAYER=""
    for p in "${priority[@]}"; do
        if echo "$players" | grep -qw "$p"; then
            PLAYER="$p"
            break
        fi
    done

    # Fallback: if nothing from priority matched, use the first playerctl entry
    if [ -z "$PLAYER" ] && [ -n "$players" ]; then
        PLAYER=$(echo "$players" | awk '{print $1}')
    fi
fi

# If still no player, show nothing
[ -z "$PLAYER" ] && exit 0

artist=$(playerctl --player="$PLAYER" metadata artist 2>/dev/null)
title=$(playerctl --player="$PLAYER" metadata title 2>/dev/null)
status=$(playerctl --player="$PLAYER" status 2>/dev/null)

# No status or stopped -> show nothing
if [ -z "$status" ] || [ "$status" = "Stopped" ]; then
    exit 0
fi

# Click actions
case "$BLOCK_BUTTON" in
    1) playerctl --player="$PLAYER" previous >/dev/null 2>&1 ;;
    2) playerctl --player="$PLAYER" play-pause >/dev/null 2>&1 ;;
    3) playerctl --player="$PLAYER" next >/dev/null 2>&1 ;;
    4) playerctl --player="$PLAYER" volume 0.01+ >/dev/null 2>&1 ;;
    5) playerctl --player="$PLAYER" volume 0.01- >/dev/null 2>&1 ;;
esac

text=""
[ -n "$artist" ] && text="$artist"
[ -n "$title" ] && text="${text:+$text - }$title"

echo "$text"
EOF

chmod +x ~/.config/i3blocks/statusbar/mediaplayer
